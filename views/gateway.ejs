<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/logo1.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="robots" content="noindex" />
  <title>BurnLink — Verifying...</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0a0a0a; color: #fff; min-height: 100vh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 2rem;
    }
    .logo-wrap { margin-bottom: 3rem; }
    .logo-wrap img { height: 48px; width: auto; display: block; }
    .card {
      border: 1px solid #1e1e1e; border-top: 2px solid #ff8c00;
      padding: 2.5rem 2.5rem 2rem;
      max-width: 380px; width: 100%; text-align: center;
    }
    .label {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em;
      text-transform: uppercase; color: #555; margin-bottom: 1rem;
    }
    h1 {
      font-size: 1.4rem; font-weight: 800; letter-spacing: -0.5px;
      color: #fff; margin-bottom: 0.6rem;
    }
    p {
      font-size: 0.82rem; color: #666; line-height: 1.8; margin-bottom: 2rem;
    }
    .widget-wrap {
      display: flex; justify-content: center; margin-bottom: 1.5rem;
    }
    .status {
      font-size: 0.8rem; color: #ff8c00; min-height: 1.2rem;
    }
    .status.error { color: #ff6b6b; }
    .footer-note {
      margin-top: 3rem; font-size: 0.72rem; color: #333; text-align: center;
    }
    .footer-note a { color: #444; text-decoration: none; }
    .footer-note a:hover { color: #666; }
  </style>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body>
  <div class="logo-wrap">
    <a href="/gateway"><img src="/logo1.png" alt="BurnLink" /></a>
  </div>

  <div class="card">
    <p class="label">Security Check</p>
    <h1>Verifying you're human</h1>
    <p>This keeps BurnLink fast and safe for everyone. It only takes a second.</p>

    <div class="widget-wrap">
      <div
        class="cf-turnstile"
        data-sitekey="<%= turnstileSiteKey %>"
        data-theme="dark"
        data-size="normal"
        data-callback="onTurnstileSuccess"
      ></div>
    </div>

    <p id="status" class="status"></p>
  </div>

  <p class="footer-note">
    Protected by <a href="https://www.cloudflare.com/products/turnstile/" target="_blank" rel="noopener noreferrer">Cloudflare Turnstile</a>
    &mdash; <a href="https://burnlink.page">BurnLink</a>
  </p>

  <script nonce="<%= cspNonce %>">
    // Fix 8: Use JSON.stringify for the full JS literal (no manual slice) and
    // replace < / > with unicode escapes so </script> cannot break out of this
    // script tag — a genuine XSS vector when returnTo contains user input.
    var RETURN_TO = <%- JSON.stringify(returnTo.startsWith('/') && !returnTo.startsWith('//') ? returnTo : '/').replace(/</g, '\\u003c').replace(/>/g, '\\u003e') %>;

    function setStatus(msg, isError) {
      var el = document.getElementById("status");
      el.textContent = msg;
      el.className = "status" + (isError ? " error" : "");
    }

    async function onTurnstileSuccess(token) {
      setStatus("Verifying...");
      try {
        var res = await fetch("/api/gateway-verify", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ "cf-turnstile-response": token, returnTo: RETURN_TO }),
        });
        var data = await res.json();
        if (data.ok) {
          setStatus("Verified! Redirecting...");
          window.location.href = data.redirect || "/";
        } else {
          setStatus(data.error || "Verification failed. Please try again.", true);
          if (typeof turnstile !== "undefined") turnstile.reset();
        }
      } catch (e) {
        setStatus("Network error. Please refresh and try again.", true);
        if (typeof turnstile !== "undefined") turnstile.reset();
      }
    }
  </script>
</body>
</html>

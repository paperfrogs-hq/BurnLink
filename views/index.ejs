  <title>BurnLink — Share files. Encrypted. Ephemeral.</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0a0a0a; color: #fff; line-height: 1.6; overflow-x: hidden; min-height: 100vh;
    }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
    header {
      padding: 1.75rem 0; border-bottom: 1px solid #1e1e1e;
      position: sticky; top: 0; background: #0a0a0a; z-index: 100;
    }
    .header-content { display: flex; justify-content: space-between; align-items: center; }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo img { height: 45px; width: auto; display: block; }
    nav { display: flex; gap: 2.5rem; }
    nav a { text-decoration: none; color: #666; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
    nav a:hover, nav a.active { color: #fff; }
    footer { border-top: 1px solid #1e1e1e; padding: 3rem 0; }
    .footer-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 2rem; margin-bottom: 2rem; }
    .footer-section h3 { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; margin-bottom: 1rem; color: #555; }
    .footer-section a { display: block; color: #777; text-decoration: none; font-size: 0.85rem; margin-bottom: 0.5rem; transition: color 0.2s; }
    .footer-section a:hover { color: #fff; }
    .footer-bottom { border-top: 1px solid #1e1e1e; padding-top: 1.5rem; color: #444; font-size: 0.78rem; }
    .error-msg { background: #1a0000; color: #ff6b6b; padding: 0.9rem 1rem; border: 1px solid #2a0000; font-size: 0.88rem; margin-bottom: 1.25rem; }
    @media (max-width: 768px) {
      nav { gap: 1.5rem; }
      .header-content { flex-wrap: wrap; gap: 1rem; }
      .footer-content { grid-template-columns: 1fr; gap: 1.5rem; }
      main { padding: 3rem 0 2rem; }
    }
    main { padding: 0 0 5rem; min-height: calc(100vh - 140px); }

    /* ── Hero top ── */
    .hero-top { padding: 3.9rem 0 4rem; border-bottom: 1px solid #141414; text-align: center; }
    .launch-slider {
      width: 100vw; overflow: hidden;
      background: linear-gradient(90deg, #0c0c0c 0%, #101010 50%, #0c0c0c 100%);
      margin: -0.9rem 0 3.6rem; margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw);
      position: relative;
    }
    .launch-slider-track {
      display: flex; align-items: center; width: max-content; white-space: nowrap;
      padding: 0.75rem 0; animation: launchTicker 22s linear infinite;
      will-change: transform;
      opacity: 0.72;
    }
    .launch-slide-item {
      display: inline-flex; align-items: center; gap: 1rem; color: #d6d6d6;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.11em; text-transform: uppercase;
      padding: 0 1rem;
    }
    .launch-slide-copy { color: #d8d8d8; }
    .launch-slide-sep {
      color: #4a4a4a; font-size: 0.72rem; letter-spacing: 0; user-select: none;
    }
    .launch-slide-item .dot {
      width: 5px; height: 5px; background: #eb583d; flex-shrink: 0;
    }
    .launch-slide-link {
      color: #eb583d; text-decoration: none; border: 1px solid #2b2b2b; background: #141414;
      padding: 0.32rem 0.7rem; font-size: 0.66rem; letter-spacing: 0.08em; transition: all 0.2s ease;
    }
    .launch-slide-link:hover {
      color: #fff; border-color: #eb583d; background: #1a1a1a;
    }
    .launch-slider::before,
    .launch-slider::after {
      content: ""; position: absolute; top: 0; bottom: 0; width: 240px; z-index: 2; pointer-events: none;
    }
    .launch-slider::before { left: 0; background: linear-gradient(90deg, #0a0a0a 0%, rgba(10,10,10,0.96) 42%, rgba(10,10,10,0.72) 68%, rgba(10,10,10,0.25) 86%, transparent 100%); }
    .launch-slider::after { right: 0; background: linear-gradient(270deg, #0a0a0a 0%, rgba(10,10,10,0.96) 42%, rgba(10,10,10,0.72) 68%, rgba(10,10,10,0.25) 86%, transparent 100%); }
    @keyframes launchTicker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .launch-slider-track { animation: none; }
    }
    .hero-top h1 {
      font-size: clamp(2.8rem, 6vw, 5.5rem); font-weight: 800; line-height: 0.95;
      letter-spacing: -0.04em; color: #fff; margin-bottom: 1.5rem;
    }
    .hero-top h1 em { font-style: normal; color: #eb583d; }
    .hero-top p { font-size: 0.9rem; color: #888; max-width: 440px; margin: 0 auto; line-height: 1.55; }


    /* ── Form grid ── */
    .hero { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; padding-top: 4rem; }
    .hero-content h2 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.6rem; letter-spacing: -0.01em; }
    .hero-content > p { font-size: 0.82rem; color: #666; line-height: 1.55; margin-bottom: 2rem; }
    .feature-rows { display: flex; flex-direction: column; }
    .feature-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid #141414; }
    .feature-row:first-child { border-top: 1px solid #141414; }
    .fr-dot { width: 4px; height: 4px; background: #eb583d; flex-shrink: 0; }
    .fr-text { font-size: 0.82rem; color: #888; }
    .upload-section { border: 1px solid #1e1e1e; border-top: 2px solid #eb583d; padding: 2.5rem; }
    .upload-section h2 { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #555; margin-bottom: 2rem; }
    form { display: grid; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
    label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #666; }
    input[type="file"], input[type="password"], input[type="text"] {
      font-size: 0.9rem; padding: 0.85rem 1rem; border: 1px solid #222; background: #111;
      color: #fff; font-family: inherit; transition: border-color 0.2s; min-height: 44px;
      -webkit-appearance: none; appearance: none; border-radius: 0; width: 100%;
    }
    input[type="file"]::file-selector-button {
      cursor: pointer; padding: 0.35rem 0.8rem; background: #1a1a1a; border: 1px solid #2a2a2a;
      border-radius: 0; color: #bbb; font-size: 0.78rem; font-weight: 500; margin-right: 0.75rem;
    }
    input[type="password"]::placeholder, input[type="text"]::placeholder { color: #444; }
    input[type="file"]:focus, input[type="password"]:focus, input[type="text"]:focus { outline: none; border-color: #eb583d; }
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear,
    input[type="text"]::-ms-reveal,
    input[type="text"]::-ms-clear {
      display: none;
    }
    input[type="password"]::-webkit-credentials-auto-fill-button,
    input[type="password"]::-webkit-textfield-decoration-container,
    input[type="text"]::-webkit-credentials-auto-fill-button,
    input[type="text"]::-webkit-textfield-decoration-container {
      visibility: hidden;
      pointer-events: none;
      position: absolute;
    }
    .drag-drop-zone {
      border: 2px dashed #2a2a2a; padding: 2rem; text-align: center; cursor: pointer;
      transition: all 0.3s ease; border-radius: 2px; background: #0f0f0f;
      display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: #666; margin-bottom: 0; margin-top: 0.5rem;
    }
    .drag-drop-zone:hover {
      border-color: #eb583d; background: #1a0a05;
    }
    .drag-drop-zone.dragover {
      border-color: #ff8c42; background: #1a0a05;
    }
    .drag-drop-icon { font-size: 2rem; margin-bottom: 0.5rem; display: block; }
    .drag-drop-text { font-size: 0.85rem; color: #888; margin-bottom: 0.25rem; display: block; }
    .drag-drop-hint { font-size: 0.75rem; color: #555; display: block; }
    .progress-container { display: none; gap: 1rem; flex-direction: column; }
    .progress-container.active { display: flex; }
    .progress-bar-track { background: #1a1a1a; height: 6px; border-radius: 3px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #eb583d, #ff8c42); border-radius: 3px; width: 0%; transition: width 0.3s ease; }
    .progress-text { font-size: 0.75rem; color: #666; text-align: right; }
    .toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 1001; }
    .toast {
      background: #1a1a1a; border: 1px solid #2a2a2a; padding: 1rem 1.25rem;
      border-radius: 2px; color: #aaa; font-size: 0.85rem;
      margin-bottom: 0.75rem; animation: slideIn 0.3s ease;
      min-width: 250px; box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }
    .toast.success { border-color: #28a745; color: #28df54; }
    .toast.error { border-color: #dc3545; color: #ff6b6b; }
    .toast.info { border-color: #eb583d; color: #ff8c42; }
    @keyframes slideIn {
      from { transform: translateX(400px); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    @keyframes slideOut {
      from { transform: translateX(0); opacity: 1; }
      to { transform: translateX(400px); opacity: 0; }
    }
    .toast.hide { animation: slideOut 0.3s ease forwards; }
    .password-input-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      width: 100%;
    }
    .password-input-group input {
      border: 1px solid #222;
      background: #111;
      padding: 0.85rem 1rem;
      color: #ccc;
      font-size: 0.95rem;
      min-height: 44px;
      -webkit-appearance: none;
      appearance: none;
      border-radius: 0;
      width: 100%;
    }
    .password-input-group input:focus {
      outline: none;
      border-color: #eb583d;
    }
    .password-toggle {
      padding: 0.5rem 0.75rem;
      background: transparent;
      color: #bbb;
      border: 1px solid #222;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      min-height: 36px;
      width: 100%;
    }
    .password-toggle:hover {
      color: #fff;
      background: rgba(235, 88, 61, 0.1);
      border-color: #eb583d;
    }
    .password-toggle:focus {
      outline: 2px solid #eb583d;
      outline-offset: -2px;
    }
    button {
      background: #eb583d; color: #000; border: none; padding: 0.9rem 1.5rem;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer; transition: opacity 0.2s; min-height: 44px;
      -webkit-appearance: none; appearance: none; border-radius: 0; width: 100%; font-family: inherit;
    }
    button:hover:not(:disabled) { opacity: 0.85; }
    button:disabled { opacity: 0.4; cursor: not-allowed; }
    .link-box { border: 1px solid #1e1e1e; padding: 1.5rem; margin-top: 1.5rem; }
    .link-box strong { display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #666; margin-bottom: 1rem; }
    #share-link { display: block; word-break: break-all; padding: 0.85rem 1rem; background: #111; border: 1px solid #222; margin-bottom: 1rem; color: #eb583d; text-decoration: none; font-family: "Monaco", "Courier New", monospace; font-size: 0.8rem; }
    .link-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
    #copy-link-btn { width: auto; padding: 0.7rem 1.25rem; }
    #share-btn { width: auto; padding: 0.7rem 1.25rem; }
    #qr-btn { width: auto; padding: 0.7rem 1.25rem; }
    .status { font-size: 0.8rem; color: #eb583d; font-weight: 500; }
    .status.error { color: #ff6b6b; }
    .qr-modal { display: none; position: fixed; inset: 0; background: rgba(0, 0, 0, 0.9); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .qr-modal.active { display: flex; }
    .qr-modal-content { background: linear-gradient(135deg, #1f1f1f 0%, #0f0f0f 100%); border: 1px solid #2a2a2a; padding: 2.5rem; max-width: 420px; position: relative; border-radius: 12px; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6), 0 0 1px rgba(235, 88, 61, 0.3); }
    .qr-modal-close { position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(235, 88, 61, 0.1); border: 1px solid rgba(235, 88, 61, 0.3); color: #bbb; font-size: 1.5rem; cursor: pointer; width: 36px; height: 36px; padding: 0; border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .qr-modal-close:hover { background: rgba(235, 88, 61, 0.2); color: #fff; border-color: #eb583d; }
    .qr-modal-header { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #eb583d; margin-bottom: 1.5rem; }
    .qr-modal-image { width: 100%; max-width: 300px; margin: 0 auto; display: block; border-radius: 8px; border: 2px solid #2a2a2a; padding: 8px; background: #fff; box-shadow: 0 8px 24px rgba(235, 88, 61, 0.15); }
    .qr-modal-text { font-size: 0.8rem; color: #999; text-align: center; margin-top: 1.5rem; line-height: 1.5; }
    .qr-modal-actions { display: flex; gap: 1rem; margin-top: 2rem; }
    .qr-action-btn { flex: 1; padding: 0.8rem 1.5rem; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; background: #eb583d; color: #000; border: none; cursor: pointer; border-radius: 6px; transition: all 0.3s; font-weight: 600; }
    .qr-action-btn:hover { background: #ff6b4a; transform: translateY(-2px); box-shadow: 0 8px 16px rgba(235, 88, 61, 0.3); }
    .qr-action-btn:active { transform: translateY(0); }
    @media (max-width: 768px) {

      .hero { grid-template-columns: 1fr; gap: 3rem; padding-top: 3rem; }
      .hero-content p { max-width: 100%; }
      .upload-section { padding: 1.5rem; }
      .hero-top { padding-top: 3rem; }
      .launch-slider { margin-top: -0.5rem; margin-bottom: 2.4rem; }
      .launch-slider-track { padding: 0.6rem 0; }
      .launch-slide-item { font-size: 0.66rem; letter-spacing: 0.08em; padding: 0 0.75rem; }
      .launch-slide-link { font-size: 0.62rem; padding: 0.28rem 0.55rem; }
      input[type="file"], input[type="password"] { font-size: 16px; }
      .link-actions { flex-direction: column; }
      #copy-link-btn { width: 100%; }
      #qr-btn { width: 100%; }
      .drag-drop-zone { padding: 1.5rem; }
      .drag-drop-icon { font-size: 1.5rem; }
      .drag-drop-text { font-size: 0.8rem; }
      .toast-container { bottom: 1rem; right: 1rem; }
      .toast { min-width: 220px; font-size: 0.8rem; }
    }
    @media (max-width: 480px) {
      .container { padding: 0 1rem; }
      .logo img { height: 38px; }
      .hero-content h1 { font-size: 1.75rem; letter-spacing: -0.5px; }
      .hero-content p { font-size: 0.88rem; }
      .upload-section { padding: 1.25rem; }
    }
  </style>
  <!-- Cloudflare Web Analytics -->
  <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "733fae826e624a4badabf309aea4d629"}'></script>

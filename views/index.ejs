  </header>

  <main>
    <!-- Hero headline -->
    <div class="hero-top">
      <div class="container">
        <div class="launch-slider" aria-label="BurnLink Product Hunt launch">
          <div class="launch-slider-track">
            <div class="launch-slide-item">
              <span class="dot" aria-hidden="true"></span>

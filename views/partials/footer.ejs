<%
  const showProductHuntBadgeValue =
    typeof showProductHuntBadge !== "undefined" &&
    typeof showProductHuntBadge === "boolean"
      ? showProductHuntBadge
      : false;
  const showOpenSourceLinkValue =
    typeof showOpenSourceLink !== "undefined" &&
    typeof showOpenSourceLink === "boolean"
      ? showOpenSourceLink
      : true;
  const comparisonLinksValue =
    typeof comparisonLinks !== "undefined" &&
    Array.isArray(comparisonLinks) &&
    comparisonLinks.length > 0
      ? comparisonLinks
      : [
          { href: "/comparisons/wetransfer", label: "BurnLink vs WeTransfer" },
          {
            href: "/comparisons/dropbox-transfer",
            label: "BurnLink vs Dropbox Transfer",
          },
          { href: "/comparisons/smash", label: "BurnLink vs Smash" },
          {
            href: "/comparisons/swisstransfer",
            label: "BurnLink vs SwissTransfer",
          },
        ];
%>
<footer>
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Product</h3>
        <a href="/about">How it works</a>
        <a href="/changelog">Changelog</a>
        <a href="/roadmap">Roadmap</a>
      </div>
      <div class="footer-section">
        <h3>Comparisons</h3>
        <% comparisonLinksValue.forEach(function (link) { %>
          <a href="<%= link.href %>"><%= link.label %></a>
        <% }); %>
      </div>
      <div class="footer-section">
        <h3>Security</h3>
        <a href="/security-policy">Security policy</a>
        <a href="/hall-of-fame">Hall of fame</a>
      </div>
      <div class="footer-section">
        <h3>Developer</h3>
        <a
          href="https://github.com/Joy-Majumder"
          target="_blank"
          rel="noopener noreferrer"
          >Joy G. Majumdar</a
        >
        <a
          href="https://github.com/niloymajumder"
          target="_blank"
          rel="noopener noreferrer"
          >Niloy Majumder</a
        >
        <a
          href="https://github.com/paperfrogs-hq/BurnLink"
          target="_blank"
          rel="noopener noreferrer"
          >GitHub</a
        >
      </div>
      <div class="footer-section">
        <h3>Paperfrogs HQ</h3>
        <p
          style="
            font-size: 0.8rem;
            color: #555;
            line-height: 1.55;
            margin-bottom: 0.75rem;
          "
        >
          An infrastructure-first studio building research-driven,
          production-ready tools. BurnLink is a Paperfrogs product.
        </p>
        <a
          href="https://paperfrogs.dev"
          target="_blank"
          rel="noopener noreferrer"
          >paperfrogs.dev</a
        >
        <a
          href="https://github.com/paperfrogs-hq"
          target="_blank"
          rel="noopener noreferrer"
          >GitHub</a
        >
      </div>
    </div>
    <div class="footer-bottom">
      <div
        style="
          display: flex;
          justify-content: space-between;
          align-items: center;
          flex-wrap: wrap;
          gap: 0.75rem;
        "
      >
        <p>
          &copy; 2026 BurnLink &mdash; A product of
          <a
            href="https://paperfrogs.dev"
            target="_blank"
            rel="noopener noreferrer"
            style="color: #555; text-decoration: none; transition: color 0.2s"
            onmouseover="this.style.color = '#fff'"
            onmouseout="this.style.color = '#555'"
            >Paperfrogs/Open</a
          >
        </p>
        <% if (showProductHuntBadgeValue) { %>
          <a
            href="https://www.producthunt.com/products/burnlink?embed=true&amp;utm_source=badge-featured&amp;utm_medium=badge&amp;utm_campaign=badge-burnlink-2"
            target="_blank"
            rel="noopener noreferrer"
            ><img
              alt="BurnLink - Share files. Encrypted. Ephemeral. | Product Hunt"
              width="250"
              height="54"
              src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1090837&amp;theme=dark&amp;t=1772737860949"
          /></a>
        <% } else if (showOpenSourceLinkValue) { %>
          <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap">
            <a
              href="https://github.com/paperfrogs-hq/BurnLink"
              target="_blank"
              rel="noopener noreferrer"
              style="
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                color: #555;
                text-decoration: none;
                font-size: 0.78rem;
                transition: color 0.2s;
              "
              onmouseover="this.style.color = '#fff'"
              onmouseout="this.style.color = '#555'"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                />
              </svg>
              Open source
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</footer>

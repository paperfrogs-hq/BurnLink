      }
      header {
        padding: 1.75rem 0;
        border-bottom: 1px solid #1e1e1e;
        position: sticky;
        top: 0;
        background: #0a0a0a;
        z-index: 100;
      }
      .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo {
        text-decoration: none;
        display: flex;
        align-items: center;
      }
      .logo img {
        height: 45px;
        width: auto;
        display: block;
      }
      nav {
        display: flex;
        gap: 2.5rem;
      }
      nav a {
        text-decoration: none;
        color: #666;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #fff;
      }

      /* ── Hero ── */
      .hero {
        padding: 7rem 0 5rem;
        border-bottom: 1px solid #1e1e1e;
      }
      .hero-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #eb583d;
        margin-bottom: 1.5rem;
      }
      .hero h1 {
        font-size: 3.8rem;
        line-height: 1;
        font-weight: 800;
        letter-spacing: -2.5px;
        max-width: 700px;
        margin-bottom: 1.75rem;
      }
      .hero h1 span {
        color: #eb583d;
      }
      .hero-sub {
        font-size: 1rem;
        color: #777;
        line-height: 1.85;
        max-width: 540px;
        margin-bottom: 2.5rem;
      }
      .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-block;
        padding: 0.85rem 1.75rem;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: opacity 0.2s;
        border-radius: 0;
      }
      .btn-primary {
        background: #eb583d;
        color: #000;
      }
      .btn-ghost {
        background: transparent;
        color: #aaa;
        border: 1px solid #333;
      }
      .btn:hover {
        opacity: 0.8;
      }

      /* ── Section chrome ── */
      section {
        padding: 5rem 0;
        border-bottom: 1px solid #1e1e1e;
      }
      .section-label {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #555;
        margin-bottom: 1rem;
      }
      .section-title {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 1rem;
      }
      .section-sub {
        font-size: 0.9rem;
        color: #666;
        line-height: 1.8;
        max-width: 500px;
        margin-bottom: 3rem;
      }

      /* ── Steps ── */
      .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: #1e1e1e;
        border: 1px solid #1e1e1e;
      }
      .step {
        background: #0a0a0a;
        padding: 2rem 1.5rem;
        position: relative;
      }
      .step-num {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        color: #333;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
      }

      .step strong {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.6rem;
        letter-spacing: 0.02em;
      }
      .step p {
        font-size: 0.82rem;
        color: #666;
        line-height: 1.7;
      }
      .step::after {
        content: "";
        position: absolute;
        top: 50%;
        right: -1px;
        transform: translateY(-50%);
        width: 1px;
        height: 40%;
        background: #eb583d;
        opacity: 0.35;
      }
      .step:last-child::after {
        display: none;
      }

      /* ── Feature cards ── */
      .features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: #1e1e1e;
        border: 1px solid #1e1e1e;
      }
      .feature {
        background: #0a0a0a;
        padding: 2rem;
      }
      .feature-tag {
        display: inline-block;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        background: #eb583d15;
        color: #eb583d;
        border: 1px solid #eb583d30;
        padding: 0.2rem 0.6rem;
        margin-bottom: 1rem;
      }
      .feature strong {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.6rem;
      }
      .feature p {
        font-size: 0.82rem;
        color: #666;
        line-height: 1.75;
      }

      /* ── Tech breakdown ── */
      .tech-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: start;
      }
      .tech-list {
        list-style: none;
      }
      .tech-list li {
        padding: 1rem 0;
        border-bottom: 1px solid #1a1a1a;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        font-size: 0.875rem;
        color: #888;
        line-height: 1.65;
      }
      .tech-list li .dot {
        flex-shrink: 0;
        width: 5px;
        height: 5px;
        background: #eb583d;
        border-radius: 50%;
        margin-top: 0.5rem;
      }
      .tech-note {
        border: 1px solid #1e1e1e;
        padding: 1.75rem;
        background: #050505;
      }
      .tech-note h4 {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #eb583d;
        margin-bottom: 1rem;
      }
      .tech-note p {
        font-size: 0.82rem;
        color: #666;
        line-height: 1.8;
      }
      .tech-note p + p {
        margin-top: 0.75rem;
      }

      /* ── Principles ── */
      .principles {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }
      .principle {
        border: 1px solid #1e1e1e;
        padding: 1.75rem;
      }
      .principle-num {
        font-size: 2rem;
        font-weight: 800;
        color: #1e1e1e;
        letter-spacing: -1px;
        margin-bottom: 0.75rem;
        line-height: 1;
      }
      .principle strong {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #ddd;
        margin-bottom: 0.5rem;
      }
      .principle p {
        font-size: 0.82rem;
        color: #666;
        line-height: 1.75;
      }

      /* ── Stats strip ── */
      .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        border: 1px solid #1e1e1e;
      }
      .stat {
        padding: 2rem;
        text-align: center;
        border-right: 1px solid #1e1e1e;
      }
      .stat:last-child {
        border-right: none;
      }
      .stat-val {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -1px;
        color: #eb583d;
        margin-bottom: 0.35rem;
      }
      .stat-label {
        font-size: 0.72rem;
        color: #555;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      /* ── Footer ── */
      footer {
        border-top: 1px solid #1e1e1e;
        padding: 3rem 0;
      }
      .footer-content {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .footer-section h3 {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 600;
        margin-bottom: 1rem;

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/logo1.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="BurnLink Security Policy — responsible disclosure, scope, and how to report vulnerabilities."
    />
    <meta name="theme-color" content="#0a0a0a" />
    <title>Security Policy - BurnLink</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background: #0a0a0a;
        color: #fff;
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
      }
      header {
        padding: 1.75rem 0;
        border-bottom: 1px solid #1e1e1e;
        position: sticky;
        top: 0;
        background: #0a0a0a;
        z-index: 100;
      }
      .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo {
        text-decoration: none;
        display: flex;
        align-items: center;
      }
      .logo img {
        height: 45px;
        width: auto;
        display: block;
      }
      nav {
        display: flex;
        gap: 2.5rem;
      }
      nav a {
        text-decoration: none;
        color: #666;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #fff;
      }
      footer {
        border-top: 1px solid #1e1e1e;
        padding: 3rem 0;
      }
      .footer-content {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .footer-section h3 {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 600;
        margin-bottom: 1rem;
        color: #555;
      }
      .footer-section a {
        display: block;
        color: #777;
        text-decoration: none;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
        transition: color 0.2s;
      }
      .footer-section a:hover {
        color: #fff;
      }
      .footer-bottom {
        border-top: 1px solid #1e1e1e;
        padding-top: 1.5rem;
        color: #444;
        font-size: 0.78rem;
      }
      main {
        padding: 6rem 0 4rem;
        min-height: calc(100vh - 140px);
      }
      .policy-content {
        max-width: 700px;
      }
      h1 {
        font-size: 3rem;
        line-height: 1.05;
        font-weight: 800;
        letter-spacing: -2px;
        color: #fff;
        margin-bottom: 1.5rem;
      }
      .intro {
        font-size: 0.95rem;
        color: #888;
        line-height: 1.8;
        margin-bottom: 3rem;
      }
      h2 {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #666;
        margin-top: 3rem;
        margin-bottom: 1.25rem;
        border-top: 1px solid #1e1e1e;
        padding-top: 2rem;
      }
      h2:first-of-type {
        border-top: none;
        padding-top: 0;
      }
      .plain-list {
        list-style: none;
        border-top: 1px solid #1e1e1e;
      }
      .plain-list li {
        padding: 0.85rem 0;
        font-size: 0.9rem;
        color: #aaa;
        border-bottom: 1px solid #1e1e1e;
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
      }
      .plain-list li::before {
        content: "";
        display: inline-block;
        width: 4px;
        height: 4px;
        background: #eb583d;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 0.55rem;
      }
      .plain-list.oos li::before {
        background: #444;
      }
      .contact-box {
        border: 1px solid #1e1e1e;
        padding: 1.75rem;
        margin-top: 2rem;
      }
      .contact-box p {
        font-size: 0.85rem;
        color: #888;
        line-height: 1.8;
        margin-bottom: 0.75rem;
      }
      .contact-box a {
        color: #eb583d;
        text-decoration: none;
        font-weight: 600;
      }
      .contact-box a:hover {
        text-decoration: underline;
      }
      .recog-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: #1e1e1e;
        border: 1px solid #1e1e1e;
        margin: 1.5rem 0;
      }
      .recog-item {
        background: #0a0a0a;
        padding: 1.25rem;
      }
      .recog-item .level {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
      }
      .recog-item .level.critical {
        color: #ff4444;
      }
      .recog-item .level.high {
        color: #eb583d;
      }
      .recog-item .level.medium {
        color: #ffd700;
      }
      .recog-item .level.low {
        color: #aaa;
      }
      .recog-item .recog-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #ccc;
      }
      .tag {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border: 1px solid #333;
        color: #888;
        margin-right: 0.4rem;
        margin-bottom: 0.4rem;
      }
      .notice {
        background: #0e0e00;
        border: 1px solid #2a2a00;
        padding: 1rem 1.25rem;
        font-size: 0.83rem;
        color: #cccc00;
        line-height: 1.7;
        margin-top: 2rem;
      }
      .cta-row {
        display: flex;
        gap: 1.5rem;
        margin-top: 3rem;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-block;
        padding: 0.8rem 1.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .btn-primary {
        background: #eb583d;
        color: #000;
      }
      .btn-ghost {
        background: transparent;
        color: #aaa;
        border: 1px solid #333;
      }
      .btn:hover {
        opacity: 0.8;
      }
      @media (max-width: 768px) {
        nav {
          gap: 1.5rem;
        }
        .header-content {
          flex-wrap: wrap;
          gap: 1rem;
        }
        .footer-content {
          grid-template-columns: 1fr;
          gap: 1.5rem;
        }
        main {
          padding: 3rem 0 2rem;
        }
        h1 {
          font-size: 2.25rem;
          letter-spacing: -1px;
        }
        .recog-grid {
          grid-template-columns: 1fr 1fr;
        }
        .cta-row {
          flex-direction: column;
        }
      }
      @media (max-width: 480px) {
        .container {
          padding: 0 1rem;
        }
        .logo img {
          height: 38px;
        }
        h1 {
          font-size: 1.75rem;
          letter-spacing: -0.5px;
        }
        .recog-grid {
          grid-template-columns: 1fr;
        }
        .intro {
          font-size: 0.88rem;
        }
      }

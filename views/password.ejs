<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Protected File</title>
  <style>
    body {
      font-family: Segoe UI, Arial, sans-serif;
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: #f2f4f7;
    }
    .card {
      width: min(400px, 92vw);
      background: #fff;
      border-radius: 10px;
      padding: 1.25rem;
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
    }
    form {
      display: grid;
      gap: 0.75rem;
    }
    input,
    button {
      font-size: 1rem;
      padding: 0.6rem;
    }
    .error {
      color: #b42318;
    }
  </style>
</head>
<body>
  <main class="card">
    <h1>This file is protected</h1>
    <p>Enter the password to decrypt and download. This link is one-time use.</p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="post">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required />
      <button type="submit">Download</button>
    </form>
  </main>
</body>
</html>

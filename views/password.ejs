<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/logo1.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Decrypt and download your secure file from BurnLink." />
  <meta name="theme-color" content="#0a0a0a" />
  <title>Decrypt &amp; Download - BurnLink</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #0a0a0a; color: #fff; line-height: 1.6; overflow-x: hidden; min-height: 100vh; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
    header { padding: 1.75rem 0; border-bottom: 1px solid #1e1e1e; position: sticky; top: 0; background: #0a0a0a; z-index: 100; }
    .header-content { display: flex; justify-content: space-between; align-items: center; }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo img { height: 45px; width: auto; display: block; }
    nav { display: flex; gap: 2.5rem; }
    nav a { text-decoration: none; color: #666; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
    nav a:hover, nav a.active { color: #fff; }
    footer { border-top: 1px solid #1e1e1e; padding: 3rem 0; }
    .footer-content { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 2rem; }
    .footer-section h3 { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; margin-bottom: 1rem; color: #555; }
    .footer-section a { display: block; color: #777; text-decoration: none; font-size: 0.85rem; margin-bottom: 0.5rem; transition: color 0.2s; }
    .footer-section a:hover { color: #fff; }
    .footer-bottom { border-top: 1px solid #1e1e1e; padding-top: 1.5rem; color: #444; font-size: 0.78rem; }
    main { padding: 6rem 0 4rem; min-height: calc(100vh - 140px); display: flex; align-items: center; }
    .decrypt-wrap { max-width: 520px; width: 100%; }
    .page-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #666; margin-bottom: 1.5rem; }
    h1 { font-size: 2.5rem; line-height: 1.1; font-weight: 800; letter-spacing: -1.5px; color: #fff; margin-bottom: 1rem; }
    .intro { font-size: 0.9rem; color: #888; line-height: 1.8; margin-bottom: 2rem; }
    .notice { border: 1px solid #1e1e1e; padding: 1rem 1.25rem; font-size: 0.82rem; color: #777; margin-bottom: 2rem; line-height: 1.7; }
    .notice strong { color: #aaa; font-weight: 600; display: block; margin-bottom: 0.25rem; }
    .decrypt-box { border: 1px solid #1e1e1e; padding: 2rem; }
    form { display: grid; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
    label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #666; }
    input[type="password"] {
      font-size: 0.9rem; padding: 0.85rem 1rem; border: 1px solid #222; background: #111;
      color: #fff; font-family: inherit; transition: border-color 0.2s; min-height: 44px;
      -webkit-appearance: none; appearance: none; border-radius: 0; width: 100%;
    }
    input[type="password"]::placeholder { color: #444; }
    input[type="password"]:focus { outline: none; border-color: #ff8c00; }
    button {
      background: #ff8c00; color: #000; border: none; padding: 0.9rem 1.5rem;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer; transition: opacity 0.2s; min-height: 44px;
      -webkit-appearance: none; appearance: none; border-radius: 0; width: 100%; font-family: inherit;
    }
    button:hover:not(:disabled) { opacity: 0.85; }
    button:disabled { opacity: 0.4; cursor: not-allowed; }
    .status { font-size: 0.8rem; color: #ff8c00; font-weight: 500; }
    .error { font-size: 0.85rem; color: #ff6b6b; font-weight: 500; }
    .error-block { background: #1a0000; color: #ff6b6b; padding: 0.9rem 1rem; border: 1px solid #2a0000; font-size: 0.88rem; margin-bottom: 1.5rem; }
    .message-container { min-height: 1.4rem; margin-top: 0.25rem; }
    
    /* View-once mode styles */
    .view-once-section { display: none; }
    .view-once-section.active { display: block; }
    .view-content {
      border: 1px solid #1e1e1e; padding: 2rem; background: #050505; margin-bottom: 1.5rem;
      max-height: 400px; overflow: auto; position: relative;
      user-select: none; -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none;
    }
    .view-content::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      pointer-events: auto; z-index: 1; display: none;
    }
    .view-content.noscreenshot::before { display: block; }
    .view-content-inner { position: relative; z-index: 0; word-break: break-word; }
    .watermark-layer {
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      overflow: hidden;
      opacity: 0.22;
    }
    .watermark-stamp {
      position: absolute;
      color: #ff8c00;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
      user-select: none;
      -webkit-user-select: none;
      will-change: transform, left, top;
    }
    .view-once-text { font-size: 0.95rem; color: #ddd; line-height: 1.6; white-space: pre-wrap; word-wrap: break-word; }
    .view-once-image { max-width: 100%; height: auto; }
    .view-once-timer {
      font-size: 0.85rem; color: #ff8c00; font-weight: 600; text-align: center;
      margin-bottom: 1rem; letter-spacing: 0.05em;
    }
    .timer-indicator {
      display: inline-block; min-width: 2rem; padding: 0 0.5rem;
      background: #1e1e1e; border-radius: 2px;
    }
    .view-once-warning {
      background: #1a1a00; border: 1px solid #2a2a00; padding: 0.75rem 1rem;
      font-size: 0.82rem; color: #ffcc00; margin-top: 1rem; line-height: 1.6;
    }
    .capture-shield {
      position: fixed;
      inset: 0;
      background: #000;
      color: #ff8c00;
      display: none;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      z-index: 9999;
      font-size: 0.9rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .capture-shield.active {
      display: flex;
    }
    .download-section { display: none; }
    .download-section.active { display: block; }
    @media print {
      body * { visibility: hidden !important; }
      .capture-shield { visibility: visible !important; display: flex !important; }
    }
    
    @media (max-width: 768px) {
      nav { gap: 1.5rem; }
      .header-content { flex-wrap: wrap; gap: 1rem; }
      .footer-content { grid-template-columns: 1fr; gap: 1.5rem; }
      main { padding: 3rem 0 2rem; }
      h1 { font-size: 1.85rem; }
      .decrypt-box { padding: 1.5rem; }
      input[type="password"] { font-size: 16px; }
      .view-content { max-height: 300px; }
    }
  </style>
  <script defer src="https://cloud.umami.is/script.js" data-website-id="5557b587-f2e2-4eb6-8edd-582164ff68da"></script>
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <a href="/" class="logo"><img src="/logo1.png" alt="BurnLink" /></a>
        <nav><a href="/">Home</a><a href="/about">About</a><a href="/security-policy">Security policy</a></nav>
      </div>
    </div>
  </header>

  <main>
    <div class="container">
      <div class="decrypt-wrap">
        <p class="page-label">Secure file download</p>
        <h1>Decrypt &amp; Download</h1>
        <p class="intro">Your secure file is ready. This link will be invalidated after <span id="intro-mode-text">download</span> — one-time access only.</p>

        <% if (error) { %>
          <div class="error-block"><%= error %></div>
        <% } %>

        <div class="notice">
          <strong>End-to-end encrypted</strong>
          All decryption happens in your browser. We never see your files.
        </div>

        <!-- Download mode section -->
        <div class="download-section <% if (mode === 'download') { %>active<% } %>">
          <div class="decrypt-box">
            <form id="decrypt-form" data-file-id="<%= fileId %>" data-requires-password="<%= requiresPassword ? 'true' : 'false' %>" data-mode="<%= mode %>">
              <% if (requiresPassword) { %>
                <div class="form-group">
                  <label for="password">Password required</label>
                  <input type="password" id="password" name="password" placeholder="Enter the password provided by the sender" required />
                </div>
              <% } else { %>
                <div class="form-group">
                  <label for="password">Password (if set by sender)</label>
                  <input type="password" id="password" name="password" placeholder="Leave blank if no password" />
                </div>
              <% } %>
              <button id="download-btn" type="submit">Decrypt &amp; Download</button>
              <div class="message-container">
                <span id="decrypt-status" class="status" aria-live="polite"></span>
                <span id="decrypt-error" class="error" aria-live="polite"></span>
              </div>
            </form>
          </div>
        </div>

        <!-- View-once mode section -->
        <div class="view-once-section <% if (mode === 'view-once') { %>active<% } %>">
          <div class="view-once-timer">
            Auto-closes in <span class="timer-indicator" id="countdown-timer">90</span> seconds
          </div>
          <% if (requiresPassword) { %>
            <div class="decrypt-box">
              <form id="viewonce-password-form" data-file-id="<%= fileId %>">
                <div class="form-group">
                  <label for="viewonce-password">Password required</label>
                  <input type="password" id="viewonce-password" name="password" placeholder="Enter the password provided by the sender" required />
                </div>
                <button type="submit">Unlock &amp; View</button>
                <div class="message-container">
                  <span id="viewonce-status" class="status" aria-live="polite"></span>
                  <span id="viewonce-error" class="error" aria-live="polite"></span>
                </div>
              </form>
            </div>
            <div id="viewonce-content-placeholder" style="display: none;">
              <div class="view-content noscreenshot">
                <div class="watermark-layer" id="viewonce-watermark-layer"></div>
                <div class="view-content-inner" id="viewonce-content"></div>
              </div>
              <div class="view-once-warning">
                <strong>Screenshot Prevention:</strong> This content cannot be copied, selected, or downloaded. Access expires in <span class="timer-indicator" id="warning-timer">90</span>s.
              </div>
              <button type="button" id="close-viewonce-btn" style="margin-top: 1rem;">Close &amp; Burn File</button>
            </div>
          <% } else { %>
            <div id="viewonce-content-placeholder" style="display: none;">
              <div class="view-content noscreenshot">
                <div class="watermark-layer" id="viewonce-watermark-layer"></div>
                <div class="view-content-inner" id="viewonce-content"></div>
              </div>
              <div class="view-once-warning">
                <strong>Screenshot Prevention:</strong> This content cannot be copied, selected, or downloaded. Access expires in <span class="timer-indicator" id="warning-timer">90</span>s.
              </div>
              <button type="button" id="close-viewonce-btn" style="margin-top: 1rem;">Close &amp; Burn File</button>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>Product</h3>
          <a href="/">Share files</a>
          <a href="/about">How it works</a>
          <a href="/security-policy">Security policy</a>
        </div>
        <div class="footer-section">
          <h3>Security</h3>
          <a href="/security-policy">Security policy</a>
          <a href="/hall-of-fame">Hall of fame</a>
        </div>
        <div class="footer-section">
          <h3>Developer</h3>
          <a href="https://github.com/Joy-Majumder" target="_blank" rel="noopener noreferrer">Joy G. Majumdar</a>
          <a href="https://github.com/Joy-Majumder/BurnLink" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://paperfrogs.dev" target="_blank" rel="noopener noreferrer">Paperfrogs Lab</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;">
          <p>&copy; 2026 BurnLink &mdash; A product of <a href="https://paperfrogs.dev" target="_blank" rel="noopener noreferrer" style="color:#555;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#555'">Paperfrogs Lab</a></p>
          <a href="https://www.producthunt.com/products/burnlink-page?utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-burnlink" target="_blank" rel="noopener noreferrer">
            <img alt="BurnLink on Product Hunt" width="200" height="43" src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1086612&theme=dark&t=1772468459571" style="display:block;" />
          </a>
        </div>
      </div>
    </div>
  </footer>

  <div id="capture-shield" class="capture-shield" aria-hidden="true">
    Protected View Once Content Hidden
  </div>

  <script nonce="<%= cspNonce %>">
    (function () {
      var PBKDF2_ITERATIONS = 210000;
      var textEncoder = new TextEncoder();
      var form = document.getElementById("decrypt-form");
      var fileId = form.dataset.fileId;
      var shareMode = form.dataset.mode || "download";
      var requiresPassword = form.dataset.requiresPassword === "true";
      var encryptedPayload = null;
      var originalFileName = "download.bin";
      var passwordInput = document.getElementById("password");
      var downloadBtn = document.getElementById("download-btn");
      var statusEl = document.getElementById("decrypt-status");
      var errorEl = document.getElementById("decrypt-error");

      // View-once variables
      var viewOnceTimer = null;
      var timeRemaining = 90;
      var countdownTimerEl = document.getElementById("countdown-timer");
      var warningTimerEl = document.getElementById("warning-timer");
      var viewOnceSection = document.querySelector(".view-once-section");
      var downloadSection = document.querySelector(".download-section");
      var introModeEl = document.getElementById("intro-mode-text");
      var viewOncePasswordForm = document.getElementById("viewonce-password-form");
      var viewOnceStatusEl = document.getElementById("viewonce-status");
      var viewOnceErrorEl = document.getElementById("viewonce-error");
      var viewOnceContentPlaceholder = document.getElementById("viewonce-content-placeholder");
      var viewOnceContentDiv = document.getElementById("viewonce-content");
      var viewOnceWatermarkLayer = document.getElementById("viewonce-watermark-layer");
      var closeViewOnceBtn = document.getElementById("close-viewonce-btn");
      var captureShieldEl = document.getElementById("capture-shield");
      var watermarkRefreshTimer = null;
      var watermarkSessionId = Math.random().toString(36).slice(2, 10).toUpperCase();
      var viewOnceSessionStarted = false;
      var fingerprintSource = [
        navigator.userAgent || "",
        navigator.platform || "",
        navigator.language || "",
        (window.screen ? window.screen.width : 0) + "x" + (window.screen ? window.screen.height : 0),
        fileId,
      ].join("|");

      // Set initial mode display
      if (shareMode === "view-once") {
        viewOnceSection.classList.add("active");
        downloadSection.classList.remove("active");
        introModeEl.textContent = "viewing";
        if (!requiresPassword) {
          // Auto-start decryption for view-once without password
          setTimeout(function() {
            authorizeViewOnce();
          }, 100);
        }
      } else {
        downloadSection.classList.add("active");
        viewOnceSection.classList.remove("active");
        introModeEl.textContent = "download";
      }

      function setStatus(message) {
        if (statusEl) {
          statusEl.textContent = message || "";
        }
        if (errorEl) {
          errorEl.textContent = "";
        }
      }

      function setError(message) {
        if (errorEl) {
          errorEl.textContent = message || "";
        }
        if (statusEl) {
          statusEl.textContent = "";
        }
      }

      function setViewOnceStatus(message) {
        if (viewOnceStatusEl) {
          viewOnceStatusEl.textContent = message || "";
        }
        if (viewOnceErrorEl) {
          viewOnceErrorEl.textContent = "";
        }
      }

      function setViewOnceError(message) {
        if (viewOnceErrorEl) {
          viewOnceErrorEl.textContent = message || "";
        }
        if (viewOnceStatusEl) {
          viewOnceStatusEl.textContent = "";
        }
      }

      function showCaptureShield(message) {
        if (!captureShieldEl) return;
        if (message) {
          captureShieldEl.textContent = message;
        }
        captureShieldEl.classList.add("active");
      }

      function hideCaptureShield() {
        if (!captureShieldEl) return;
        captureShieldEl.classList.remove("active");
      }

      function isViewOnceActive() {
        return shareMode === "view-once";
      }

      var _hiddenContentBackup = null;

      function hideViewOnceContent(reason) {
        if (!isViewOnceActive() || !viewOnceSessionStarted) return;
        // Actually remove content from DOM so screenshot captures nothing
        if (viewOnceContentDiv && viewOnceContentDiv.childNodes.length > 0) {
          _hiddenContentBackup = viewOnceContentDiv.innerHTML;
          viewOnceContentDiv.innerHTML = "";
        }
        showCaptureShield(reason || "Protected Content Hidden");
      }

      function restoreViewOnceContent() {
        if (!isViewOnceActive()) return;
        if (_hiddenContentBackup !== null && viewOnceContentDiv) {
          viewOnceContentDiv.innerHTML = _hiddenContentBackup;
          _hiddenContentBackup = null;
        }
        hideCaptureShield();
      }

      function shortFingerprint(input) {
        var hash = 5381;
        for (var index = 0; index < input.length; index++) {
          hash = ((hash << 5) + hash) + input.charCodeAt(index);
          hash = hash >>> 0;
        }
        return ("00000000" + hash.toString(16)).slice(-8).toUpperCase();
      }

      function watermarkText() {
        var now = new Date();
        var hh = String(now.getHours()).padStart(2, "0");
        var mm = String(now.getMinutes()).padStart(2, "0");
        var ss = String(now.getSeconds()).padStart(2, "0");
        var recipientFingerprint = shortFingerprint(fingerprintSource);
        return "BURNLINK • VIEW-ONCE • FILE " + fileId + " • SESSION " + watermarkSessionId + " • FP " + recipientFingerprint + " • " + hh + ":" + mm + ":" + ss;
      }

      function renderDynamicWatermark() {
        if (!viewOnceWatermarkLayer) return;

        viewOnceWatermarkLayer.innerHTML = "";
        var stampText = watermarkText();
        var rows = 6;
        var cols = 3;

        for (var row = 0; row < rows; row++) {
          for (var col = 0; col < cols; col++) {
            var stamp = document.createElement("div");
            stamp.className = "watermark-stamp";
            stamp.textContent = stampText;
            var leftJitter = Math.random() * 4 - 2;
            var topJitter = Math.random() * 4 - 2;
            var rotation = -28 + Math.random() * 14;
            stamp.style.left = (col * 35 + (row % 2 === 0 ? 2 : 10) + leftJitter) + "%";
            stamp.style.top = (row * 18 + 3 + topJitter) + "%";
            stamp.style.transform = "rotate(" + rotation + "deg)";
            stamp.style.opacity = String(0.55 + Math.random() * 0.25);
            viewOnceWatermarkLayer.appendChild(stamp);
          }
        }
      }

      function startWatermarkRefresh() {
        clearInterval(watermarkRefreshTimer);
        renderDynamicWatermark();
        watermarkRefreshTimer = setInterval(renderDynamicWatermark, 3000);
      }

      function stopWatermarkRefresh() {
        clearInterval(watermarkRefreshTimer);
        watermarkRefreshTimer = null;
      }

      function fromBase64Url(base64Url) {
        var base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
        while (base64.length % 4) {
          base64 += "=";
        }
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i += 1) {
          bytes[i] = binary.charCodeAt(i);
        }
        return bytes;
      }

      function parseEnvelope(payload) {
        if (payload.length < 8) {
          throw new Error("Encrypted file is invalid.");
        }

        // magic "FSE1"
        if (
          payload[0] !== 70 ||
          payload[1] !== 83 ||
          payload[2] !== 69 ||
          payload[3] !== 49
        ) {
          throw new Error("Unsupported encrypted file format.");
        }

        var version = payload[4];
        var mode = payload[5];
        var saltLen = payload[6];
        var ivLen = payload[7];

        if (version !== 1) {
          throw new Error("Unsupported encryption version.");
        }

        var offset = 8;
        var salt = payload.slice(offset, offset + saltLen);
        offset += saltLen;

        var iv = payload.slice(offset, offset + ivLen);
        offset += ivLen;

        var ciphertext = payload.slice(offset);
        if (ciphertext.length === 0) {
          throw new Error("Encrypted file payload is empty.");
        }

        return {
          mode: mode,
          salt: salt,
          iv: iv,
          ciphertext: ciphertext,
        };
      }

      async function deriveKeyFromPassword(password, salt) {
        var baseKey = await crypto.subtle.importKey(
          "raw",
          textEncoder.encode(password),
          "PBKDF2",
          false,
          ["deriveKey"]
        );

        return crypto.subtle.deriveKey(
          {
            name: "PBKDF2",
            salt: salt,
            iterations: PBKDF2_ITERATIONS,
            hash: "SHA-256",
          },
          baseKey,
          {
            name: "AES-GCM",
            length: 256,
          },
          false,
          ["decrypt"]
        );
      }

      // Derives the same server-side authentication token as upload.js.
      // The raw password never reaches the server; only a bcrypt hash of
      // this derived token is stored, keeping the actual decryption key
      // entirely client-side.
      async function deriveServerToken(password) {
        var baseKey = await crypto.subtle.importKey(
          "raw",
          textEncoder.encode(password),
          "PBKDF2",
          false,
          ["deriveKey"]
        );
        var derivedKey = await crypto.subtle.deriveKey(
          {
            name: "PBKDF2",
            salt: textEncoder.encode("burnlink-server-auth-v1"),
            iterations: 1000,
            hash: "SHA-256",
          },
          baseKey,
          { name: "AES-GCM", length: 256 },
          true,
          ["encrypt"]
        );
        var raw = new Uint8Array(await crypto.subtle.exportKey("raw", derivedKey));
        return Array.from(raw).map(function (b) { return b.toString(16).padStart(2, "0"); }).join("");
      }

      async function importRawAesKey(rawKey) {
        return crypto.subtle.importKey(
          "raw",
          rawKey,
          { name: "AES-GCM" },
          false,
          ["decrypt"]
        );
      }

      // Derives a server-side authentication token from the password.
      // Mirrors the same logic in upload.js so the server can verify it with
      // bcrypt without ever seeing the raw password or the AES encryption key.
      async function deriveServerToken(password) {
        var baseKey = await crypto.subtle.importKey(
          "raw",
          textEncoder.encode(password),
          "PBKDF2",
          false,
          ["deriveKey"]
        );
        var derivedKey = await crypto.subtle.deriveKey(
          {
            name: "PBKDF2",
            salt: textEncoder.encode("burnlink-server-auth-v1"),
            iterations: 1000,
            hash: "SHA-256",
          },
          baseKey,
          { name: "AES-GCM", length: 256 },
          true,
          ["encrypt"]
        );
        var raw = new Uint8Array(await crypto.subtle.exportKey("raw", derivedKey));
        return Array.from(raw).map(function (b) { return b.toString(16).padStart(2, "0"); }).join("");
      }

      function getLinkKeyBytes() {
        var hash = window.location.hash || "";
        if (!hash.startsWith("#")) return null;
        var params = new URLSearchParams(hash.slice(1));
        var keyString = params.get("k");
        if (!keyString) return null;

        try {
          return fromBase64Url(keyString);
        } catch (error) {
          return null;
        }
      }

      async function fetchEncryptedPayload() {
        if (encryptedPayload) {
          return encryptedPayload;
        }

        setStatus("Fetching encrypted file...");
        var response;
        if (requiresPassword) {
          var serverToken = await deriveServerToken(passwordInput.value || "");
          response = await fetch("/file/" + fileId + "/raw", {
            method: "POST",
            headers: {
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: new URLSearchParams({
              password: serverToken,
            }).toString(),
          });
        } else {
          response = await fetch("/file/" + fileId + "/raw");
        }

        if (!response.ok) {
          var message = "This link is invalid or already used.";
          try {
            var body = await response.json();
            if (body && body.error) {
              message = body.error;
            }
          } catch (e) {
            // ignore JSON parse errors
          }
          throw new Error(message);
        }

        var fileNameHeader = response.headers.get("x-file-name");
        if (fileNameHeader) {
          originalFileName = decodeURIComponent(fileNameHeader);
        }

        encryptedPayload = new Uint8Array(await response.arrayBuffer());
        return encryptedPayload;
      }

      async function decryptPayload(payload, password) {
        var envelope = parseEnvelope(payload);
        var key;

        if (envelope.mode === 1) {
          if (!password) {
            throw new Error("Password required for this file.");
          }
          key = await deriveKeyFromPassword(password, envelope.salt);
        } else if (envelope.mode === 2) {
          var linkKeyBytes = getLinkKeyBytes();
          if (!linkKeyBytes || linkKeyBytes.length !== 32) {
            throw new Error("Missing or invalid decryption key in link.");
          }
          key = await importRawAesKey(linkKeyBytes);
        } else {
          throw new Error("Unknown encryption mode.");
        }

        var plainBuffer = await crypto.subtle.decrypt(
          { name: "AES-GCM", iv: envelope.iv },
          key,
          envelope.ciphertext
        );

        return new Uint8Array(plainBuffer);
      }

      function triggerDownload(bytes, fileName) {
        var blob = new Blob([bytes], { type: "application/octet-stream" });
        var objectUrl = URL.createObjectURL(blob);
        var a = document.createElement("a");
        a.href = objectUrl;
        a.download = fileName || "download.bin";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(objectUrl);
      }

      async function fetchEncryptedPayloadViewOnce(password) {
        setViewOnceStatus("Fetching encrypted file...");
        var serverToken = await deriveServerToken(password || "");
        var response = await fetch("/file/" + fileId + "/raw", {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded",
          },
          body: new URLSearchParams({
            password: serverToken,
          }).toString(),
        });

        if (!response.ok) {
          var message = "This link is invalid or already used.";
          try {
            var body = await response.json();
            if (body && body.error) {
              message = body.error;
            }
          } catch (e) {
            // ignore JSON parse errors
          }
          throw new Error(message);
        }

        var fileNameHeader = response.headers.get("x-file-name");
        if (fileNameHeader) {
          originalFileName = decodeURIComponent(fileNameHeader);
        }

        return new Uint8Array(await response.arrayBuffer());
      }

      function getMimeType(filename) {
        var ext = (filename || "").split(".").pop().toLowerCase();
        var map = {
          // images
          jpg: "image/jpeg", jpeg: "image/jpeg", png: "image/png",
          gif: "image/gif", webp: "image/webp", svg: "image/svg+xml",
          bmp: "image/bmp", ico: "image/x-icon", avif: "image/avif",
          // video
          mp4: "video/mp4", webm: "video/webm", mov: "video/quicktime",
          mkv: "video/x-matroska", avi: "video/x-msvideo",
          // audio
          mp3: "audio/mpeg", wav: "audio/wav", ogg: "audio/ogg",
          m4a: "audio/mp4", flac: "audio/flac",
          // documents
          pdf: "application/pdf",
          // text
          txt: "text/plain", md: "text/plain", csv: "text/csv",
          json: "application/json", xml: "text/xml",
          html: "text/html", htm: "text/html",
          js: "text/javascript", css: "text/css",
        };
        return map[ext] || "application/octet-stream";
      }

      function displayViewOnceContent(bytes) {
        var mime = getMimeType(originalFileName);
        var blob = new Blob([bytes], { type: mime });
        var objectUrl = URL.createObjectURL(blob);
        var isImage = mime.startsWith("image/");
        var isVideo = mime.startsWith("video/");
        var isAudio = mime.startsWith("audio/");
        var isPdf = mime === "application/pdf";
        var isText = mime.startsWith("text/") || mime === "application/json";

        viewOnceContentDiv.innerHTML = "";

        if (isImage) {
          var img = document.createElement("img");
          img.src = objectUrl;
          img.alt = originalFileName || "Image";
          img.style.cssText = "max-width:100%;max-height:70vh;display:block;margin:0 auto;border-radius:8px;";
          viewOnceContentDiv.appendChild(img);

        } else if (isVideo) {
          var video = document.createElement("video");
          video.src = objectUrl;
          video.controls = true;
          video.style.cssText = "max-width:100%;max-height:70vh;display:block;margin:0 auto;";
          viewOnceContentDiv.appendChild(video);

        } else if (isAudio) {
          var audio = document.createElement("audio");
          audio.src = objectUrl;
          audio.controls = true;
          audio.style.cssText = "width:100%;display:block;margin:1rem auto;";
          viewOnceContentDiv.appendChild(audio);

        } else if (isPdf) {
          var iframe = document.createElement("iframe");
          iframe.src = objectUrl;
          iframe.style.cssText = "width:100%;height:70vh;border:none;border-radius:8px;";
          viewOnceContentDiv.appendChild(iframe);

        } else if (isText) {
          try {
            var text = new TextDecoder("utf-8", { fatal: true }).decode(bytes);
            var pre = document.createElement("pre");
            pre.style.cssText = "white-space:pre-wrap;word-break:break-word;max-height:70vh;overflow:auto;text-align:left;";
            pre.textContent = text;
            viewOnceContentDiv.appendChild(pre);
          } catch (e) {
            var fallback = document.createElement("p");
            fallback.textContent = "Could not decode text content.";
            viewOnceContentDiv.appendChild(fallback);
          }

        } else {
          var msg = document.createElement("p");
          msg.textContent = "File received (" + (bytes.length / 1024).toFixed(1) + " KB) — " + (originalFileName || "file") + ". This format cannot be previewed inline.";
          viewOnceContentDiv.appendChild(msg);
        }

        viewOnceContentPlaceholder.style.display = "block";
        viewOnceSessionStarted = true;
        startWatermarkRefresh();
        hideCaptureShield();
      }

      function startViewOnceTimer() {
        timeRemaining = 90;
        clearInterval(viewOnceTimer);
        updateCountdownDisplay();
        viewOnceTimer = setInterval(function() {
          timeRemaining--;
          updateCountdownDisplay();
          if (timeRemaining <= 0) {
            clearInterval(viewOnceTimer);
            expireViewOnce();
          }
        }, 1000);
      }

      function updateCountdownDisplay() {
        if (countdownTimerEl) {
          countdownTimerEl.textContent = Math.max(0, timeRemaining);
        }
        if (warningTimerEl) {
          warningTimerEl.textContent = Math.max(0, timeRemaining);
        }
      }

      function burnFileOnServer() {
        // fire-and-forget fallback used only on pagehide
        try { navigator.sendBeacon("/file/" + fileId + "/burn"); } catch(e) {}
      }

      async function burnFileOnServerAsync() {
        try {
          var r = await fetch("/file/" + fileId + "/burn", { method: "POST" });
          // 404 = file already gone (prior burn or expiry) — treat as success
          if (r.status === 404) { console.log("[burn] 404 - already gone"); return true; }
          var body;
          try { body = await r.json(); } catch(e) { body = {}; }
          console.log("[burn] response status:", r.status, "body:", JSON.stringify(body));
          return r.ok;
        } catch(e) {
          console.error("[burn] fetch error:", e);
          return false;
        }
      }

      function showBurnedState() {
        clearInterval(viewOnceTimer);
        stopWatermarkRefresh();
        viewOnceContentPlaceholder.style.display = "none";
        viewOnceContentDiv.innerHTML = "";
        if (closeViewOnceBtn) closeViewOnceBtn.disabled = true;
        if (viewOnceErrorEl) viewOnceErrorEl.textContent = "This file has been permanently destroyed. This URL is no longer valid.";
        showCaptureShield("File Burned. URL Dead.");
      }

      async function expireViewOnce() {
        // Show burned UI immediately so user can't keep reading
        showBurnedState();
        // Then actually delete on server using full fetch (page is still open)
        await burnFileOnServerAsync();
      }

      async function authorizeViewOnce() {
        try {
          var payload = await fetchEncryptedPayload();
          setViewOnceStatus("Decrypting content...");
          var plainBytes = await decryptPayload(payload, "");
          displayViewOnceContent(plainBytes);
          startViewOnceTimer();
          setViewOnceStatus("");
        } catch (error) {
          setViewOnceError(error.message || "Failed to decrypt file.");
        }
      }

      async function handleViewOncePassword(event) {
        event.preventDefault();
        var password = document.getElementById("viewonce-password").value || "";
        setViewOnceError("");
        setViewOnceStatus("");

        try {
          var payload = await fetchEncryptedPayloadViewOnce(password);
          setViewOnceStatus("Decrypting content...");
          var plainBytes = await decryptPayload(payload, password);
          displayViewOnceContent(plainBytes);
          viewOncePasswordForm.style.display = "none";
          startViewOnceTimer();
          setViewOnceStatus("");
        } catch (error) {
          setViewOnceError(error.message || "Failed to decrypt file.");
        }
      }

      async function handleCloseViewOnce() {
        if (closeViewOnceBtn) {
          closeViewOnceBtn.disabled = true;
          closeViewOnceBtn.textContent = "Burning...";
        }
        var burned = await burnFileOnServerAsync();
        if (!burned) {
          // Burn failed server-side — re-enable button and show error
          if (closeViewOnceBtn) {
            closeViewOnceBtn.disabled = false;
            closeViewOnceBtn.textContent = "Close & Burn";
          }
          if (viewOnceErrorEl) viewOnceErrorEl.textContent = "Burn failed. Check your network and try again.";
          return;
        }
        showBurnedState();
      }

      async function handleDecrypt(event) {
        event.preventDefault();
        setError("");
        setStatus("");
        downloadBtn.disabled = true;

        try {
          var payload = await fetchEncryptedPayload();
          setStatus("Decrypting in your browser...");
          var plainBytes = await decryptPayload(payload, passwordInput.value || "");
          triggerDownload(plainBytes, originalFileName);
          setStatus("Download complete.");
        } catch (error) {
          setError(error.message || "Failed to decrypt file.");
        } finally {
          downloadBtn.disabled = false;
        }
      }

      // Event listeners
      if (form) {
        form.addEventListener("submit", handleDecrypt);
      }

      if (viewOncePasswordForm) {
        viewOncePasswordForm.addEventListener("submit", handleViewOncePassword);
      }

      if (closeViewOnceBtn) {
        closeViewOnceBtn.addEventListener("click", handleCloseViewOnce);
      }

      if (isViewOnceActive()) {
        // Burn file if user closes tab or navigates away (only after session started)
        window.addEventListener("pagehide", function() {
          if (viewOnceSessionStarted) {
            burnFileOnServer();
          }
        });

        document.addEventListener("visibilitychange", function() {
          if (document.hidden) {
            hideViewOnceContent("Protected Content Hidden");
          } else {
            restoreViewOnceContent();
          }
        });

        window.addEventListener("blur", function () {
          hideViewOnceContent("Protected Content Hidden");
        });

        window.addEventListener("focus", function () {
          restoreViewOnceContent();
        });

        document.addEventListener("keydown", function (event) {
          var key = (event.key || "").toLowerCase();
          var looksLikeScreenshot =
            key === "printscreen" ||
            (event.metaKey && event.shiftKey && (key === "3" || key === "4" || key === "5")) ||
            (event.ctrlKey && event.shiftKey && key === "s") ||
            (event.metaKey && event.ctrlKey && key === "4");

          if (looksLikeScreenshot) {
            event.preventDefault();
            // Remove content immediately before browser renders next frame
            hideViewOnceContent("Screenshot Blocked");
            // Restore after 1.5s so user can continue reading
            setTimeout(restoreViewOnceContent, 1500);
          }
        });

        ["contextmenu", "copy", "cut", "selectstart", "dragstart"].forEach(function (eventName) {
          document.addEventListener(eventName, function (event) {
            var targetInsideProtectedArea = viewOnceSection && viewOnceSection.contains(event.target);
            if (targetInsideProtectedArea) {
              event.preventDefault();
            }
          });
        });
      }
    })();
  </script>
</body>
</html>


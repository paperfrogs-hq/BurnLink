  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #0a0a0a; color: #fff; line-height: 1.6; overflow-x: hidden; min-height: 100vh; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
    header { padding: 1.75rem 0; border-bottom: 1px solid #1e1e1e; position: sticky; top: 0; background: #0a0a0a; z-index: 100; }
    .header-content { display: flex; justify-content: space-between; align-items: center; }
    .logo { text-decoration: none; display: flex; align-items: center; }
    .logo img { height: 45px; width: auto; display: block; }
    nav { display: flex; gap: 2.5rem; }
    nav a { text-decoration: none; color: #666; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
    nav a:hover, nav a.active { color: #fff; }
    footer { border-top: 1px solid #1e1e1e; padding: 3rem 0; }
    .footer-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 2rem; margin-bottom: 2rem; }
    .footer-section h3 { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; margin-bottom: 1rem; color: #555; }
    .footer-section a { display: block; color: #777; text-decoration: none; font-size: 0.85rem; margin-bottom: 0.5rem; transition: color 0.2s; }
    .footer-section a:hover { color: #fff; }
    .footer-bottom { border-top: 1px solid #1e1e1e; padding-top: 1.5rem; color: #444; font-size: 0.78rem; }
    main { padding: 6rem 0 4rem; min-height: calc(100vh - 140px); display: flex; align-items: center; }
    .decrypt-wrap { max-width: 520px; width: 100%; }
    .page-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #666; margin-bottom: 1.5rem; }
    h1 { font-size: 2.5rem; line-height: 1.1; font-weight: 800; letter-spacing: -1.5px; color: #fff; margin-bottom: 1rem; }
    .intro { font-size: 0.9rem; color: #888; line-height: 1.55; margin-bottom: 2rem; }
    .notice { border: 1px solid #1e1e1e; padding: 1rem 1.25rem; font-size: 0.82rem; color: #777; margin-bottom: 2rem; line-height: 1.55; }
    .notice strong { color: #aaa; font-weight: 600; display: block; margin-bottom: 0.25rem; }
    .decrypt-box { border: 1px solid #1e1e1e; padding: 2rem; }
    form { display: grid; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
    label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #666; }
    input[type="password"] {
      font-size: 0.9rem; padding: 0.85rem 1rem; border: 1px solid #222; background: #111;
      color: #fff; font-family: inherit; transition: border-color 0.2s; min-height: 44px;
      -webkit-appearance: none; appearance: none; border-radius: 0; width: 100%;
    }
    input[type="password"]::placeholder { color: #444; }
    input[type="password"]:focus { outline: none; border-color: #eb583d; }
    button {
      background: #eb583d; color: #000; border: none; padding: 0.9rem 1.5rem;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer; transition: opacity 0.2s; min-height: 44px;
      -webkit-appearance: none; appearance: none; border-radius: 0; width: 100%; font-family: inherit;
    }
    button:hover:not(:disabled) { opacity: 0.85; }
    button:disabled { opacity: 0.4; cursor: not-allowed; }
    .password-input-group {
      display: flex;
      flex-direction: column;

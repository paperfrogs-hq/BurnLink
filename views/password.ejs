<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta id="__bl_lk__" data-lk="<%= linkKey || '' %>">
  <script nonce="<%= cspNonce %>">
    // SECURITY: Key is injected server-side via a data attribute (no EJS in JS).
    // Falls back to URL hash for backward compatibility with old shared links.
    // The meta element is removed immediately after reading.
    (function(){
      var el = document.getElementById('__bl_lk__');
      window.__BL_KEY__ = (el && el.getAttribute('data-lk')) || location.hash.slice(1);
      if (el) el.parentNode.removeChild(el);
      history.replaceState(null, '', location.pathname + location.search);
    })();
  </script>
  <link rel="icon" type="image/png" href="/logo1.png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

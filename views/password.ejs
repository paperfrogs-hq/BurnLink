    }
    .watermark-stamp {
      position: absolute;
      color: #eb583d;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
      user-select: none;
      -webkit-user-select: none;
      will-change: transform, left, top;
    }
    .view-once-text { font-size: 0.95rem; color: #ddd; line-height: 1.6; white-space: pre-wrap; word-wrap: break-word; }
    .view-once-image { max-width: 100%; height: auto; }
    .view-once-timer {
      font-size: 0.85rem; color: #eb583d; font-weight: 600; text-align: center;
      margin-bottom: 1rem; letter-spacing: 0.05em;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      width: 100%;
    }
    .file-size-badge {
      color: #888;
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0;
      background: #0f0f0f;
      padding: 0.35rem 0.65rem;
      border-radius: 3px;
      border: 1px solid #1a1a1a;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .timer-indicator {
      display: inline-block; min-width: 2rem; padding: 0 0.5rem;
      background: #1e1e1e; border-radius: 2px;
    }
    .view-once-warning {
      background: #1a1a00; border: 1px solid #2a2a00; padding: 0.75rem 1rem;
      font-size: 0.82rem; color: #ffcc00; margin-top: 1rem; line-height: 1.6;
    }
    .progress-wrap { margin-top: 0.75rem; }
    .progress-bar-track { background: #1a1a1a; height: 4px; width: 100%; border-radius: 2px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: #eb583d; border-radius: 2px; width: 0%; transition: width 0.25s linear; }
    .progress-label { font-size: 0.72rem; color: #555; margin-top: 0.35rem; }
    .capture-shield {
      position: fixed;
      inset: 0;
      background: #000;
      color: #ff8c00;
      display: none;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      z-index: 9999;
      font-size: 0.9rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .capture-shield.active {
      display: flex;
    }
    .download-section { display: none; }
    .download-section.active { display: block; }
    @media print {
      body * { visibility: hidden !important; }
      .capture-shield { visibility: visible !important; display: flex !important; }
    }
    
    @media (max-width: 768px) {
      nav { gap: 1.5rem; }
      .header-content { flex-wrap: wrap; gap: 1rem; }
      .footer-content { grid-template-columns: 1fr; gap: 1.5rem; }
      main { padding: 3rem 0 2rem; }
      h1 { font-size: 1.85rem; }
      .decrypt-box { padding: 1.5rem; }
      input[type="password"] { font-size: 16px; }
      .view-content { max-height: 70vh; }
      .view-once-timer { font-size: 0.75rem; }
    }
    @media (max-width: 480px) {
      .container { padding: 0 1rem; }
      .logo img { height: 38px; }
      h1 { font-size: 1.5rem; letter-spacing: -0.5px; }
      .decrypt-box { padding: 1.25rem; }
      .notice { padding: 0.75rem 1rem; }
    }
  </style>

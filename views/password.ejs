<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Decrypt File</title>
  <style>
    body {
      font-family: Segoe UI, Arial, sans-serif;
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: #f2f4f7;
    }
    .card {
      width: min(480px, 92vw);
      background: #fff;
      border-radius: 10px;
      padding: 1.25rem;
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
    }
    form {
      display: grid;
      gap: 0.75rem;
    }
    input,
    button {
      font-size: 1rem;
      padding: 0.6rem;
    }
    .error {
      color: #b42318;
    }
    .status {
      color: #475467;
      font-size: 0.9rem;
    }
    .footer {
      margin-top: 1rem;
      font-size: 0.9rem;
      color: #475467;
      text-align: center;
    }
  </style>
</head>
<body>
  <main class="card">
    <h1>Decrypt and Download</h1>
    <p>End-to-end encrypted one-time link. After first data fetch, this URL is burned.</p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form id="decrypt-form">
      <label for="password">Password (only if sender used one)</label>
      <input type="password" id="password" name="password" />
      <button id="download-btn" type="submit">Decrypt & Download</button>
      <span id="decrypt-status" class="status" aria-live="polite"></span>
      <span id="decrypt-error" class="error" aria-live="polite"></span>
    </form>

    <footer class="footer">
      <a href="/about">About</a> |
      Developer: <a href="https://github.com/Joy-Majumder" target="_blank" rel="noopener noreferrer">Joy G. Majumdar</a>
    </footer>
  </main>

  <script>
    (function () {
      var PBKDF2_ITERATIONS = 210000;
      var textEncoder = new TextEncoder();
      var fileId = "<%= fileId %>";
      var requiresPassword = <%= requiresPassword ? "true" : "false" %>;
      var encryptedPayload = null;
      var originalFileName = "download.bin";

      var form = document.getElementById("decrypt-form");
      var passwordInput = document.getElementById("password");
      var downloadBtn = document.getElementById("download-btn");
      var statusEl = document.getElementById("decrypt-status");
      var errorEl = document.getElementById("decrypt-error");

      function setStatus(message) {
        statusEl.textContent = message || "";
      }

      function setError(message) {
        errorEl.textContent = message || "";
      }

      function fromBase64Url(base64Url) {
        var base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
        while (base64.length % 4) {
          base64 += "=";
        }
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i += 1) {
          bytes[i] = binary.charCodeAt(i);
        }
        return bytes;
      }

      function parseEnvelope(payload) {
        if (payload.length < 8) {
          throw new Error("Encrypted file is invalid.");
        }

        // magic "FSE1"
        if (
          payload[0] !== 70 ||
          payload[1] !== 83 ||
          payload[2] !== 69 ||
          payload[3] !== 49
        ) {
          throw new Error("Unsupported encrypted file format.");
        }

        var version = payload[4];
        var mode = payload[5];
        var saltLen = payload[6];
        var ivLen = payload[7];

        if (version !== 1) {
          throw new Error("Unsupported encryption version.");
        }

        var offset = 8;
        var salt = payload.slice(offset, offset + saltLen);
        offset += saltLen;

        var iv = payload.slice(offset, offset + ivLen);
        offset += ivLen;

        var ciphertext = payload.slice(offset);
        if (ciphertext.length === 0) {
          throw new Error("Encrypted file payload is empty.");
        }

        return {
          mode: mode,
          salt: salt,
          iv: iv,
          ciphertext: ciphertext,
        };
      }

      async function deriveKeyFromPassword(password, salt) {
        var baseKey = await crypto.subtle.importKey(
          "raw",
          textEncoder.encode(password),
          "PBKDF2",
          false,
          ["deriveKey"]
        );

        return crypto.subtle.deriveKey(
          {
            name: "PBKDF2",
            salt: salt,
            iterations: PBKDF2_ITERATIONS,
            hash: "SHA-256",
          },
          baseKey,
          {
            name: "AES-GCM",
            length: 256,
          },
          false,
          ["decrypt"]
        );
      }

      async function importRawAesKey(rawKey) {
        return crypto.subtle.importKey(
          "raw",
          rawKey,
          { name: "AES-GCM" },
          false,
          ["decrypt"]
        );
      }

      function getLinkKeyBytes() {
        var hash = window.location.hash || "";
        if (!hash.startsWith("#")) return null;
        var params = new URLSearchParams(hash.slice(1));
        var keyString = params.get("k");
        if (!keyString) return null;

        try {
          return fromBase64Url(keyString);
        } catch (error) {
          return null;
        }
      }

      async function fetchEncryptedPayload() {
        if (encryptedPayload) {
          return encryptedPayload;
        }

        setStatus("Fetching encrypted file...");
        var response;
        if (requiresPassword) {
          response = await fetch("/file/" + fileId + "/raw", {
            method: "POST",
            headers: {
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: new URLSearchParams({
              password: passwordInput.value || "",
            }).toString(),
          });
        } else {
          response = await fetch("/file/" + fileId + "/raw");
        }

        if (!response.ok) {
          var message = "This link is invalid or already used.";
          try {
            var body = await response.json();
            if (body && body.error) {
              message = body.error;
            }
          } catch (e) {
            // ignore JSON parse errors
          }
          throw new Error(message);
        }

        var fileNameHeader = response.headers.get("x-file-name");
        if (fileNameHeader) {
          originalFileName = decodeURIComponent(fileNameHeader);
        }

        encryptedPayload = new Uint8Array(await response.arrayBuffer());
        return encryptedPayload;
      }

      async function decryptPayload(payload, password) {
        var envelope = parseEnvelope(payload);
        var key;

        if (envelope.mode === 1) {
          if (!password) {
            throw new Error("Password required for this file.");
          }
          key = await deriveKeyFromPassword(password, envelope.salt);
        } else if (envelope.mode === 2) {
          var linkKeyBytes = getLinkKeyBytes();
          if (!linkKeyBytes || linkKeyBytes.length !== 32) {
            throw new Error("Missing or invalid decryption key in link.");
          }
          key = await importRawAesKey(linkKeyBytes);
        } else {
          throw new Error("Unknown encryption mode.");
        }

        var plainBuffer = await crypto.subtle.decrypt(
          { name: "AES-GCM", iv: envelope.iv },
          key,
          envelope.ciphertext
        );

        return new Uint8Array(plainBuffer);
      }

      function triggerDownload(bytes, fileName) {
        var blob = new Blob([bytes], { type: "application/octet-stream" });
        var objectUrl = URL.createObjectURL(blob);
        var a = document.createElement("a");
        a.href = objectUrl;
        a.download = fileName || "download.bin";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(objectUrl);
      }

      async function handleDecrypt(event) {
        event.preventDefault();
        setError("");
        setStatus("");
        downloadBtn.disabled = true;

        try {
          var payload = await fetchEncryptedPayload();
          setStatus("Decrypting in your browser...");
          var plainBytes = await decryptPayload(payload, passwordInput.value || "");
          triggerDownload(plainBytes, originalFileName);
          setStatus("Download complete.");
        } catch (error) {
          setError(error.message || "Failed to decrypt file.");
        } finally {
          downloadBtn.disabled = false;
        }
      }

      form.addEventListener("submit", handleDecrypt);
    })();
  </script>
</body>
</html>

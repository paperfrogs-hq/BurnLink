<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Decrypt and download your secure file from BurnLink." />
  <meta name="theme-color" content="#0a0a0a" />
  <title>Decrypt & Download</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1410 100%);
      color: #ffffff;
      line-height: 1.6;
      overflow-x: hidden;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-40px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(60px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    header {
      padding: 2rem 0;
      position: sticky;
      top: 0;
      background: rgba(10, 10, 10, 0.8);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 140, 0, 0.15);
      z-index: 100;
      animation: fadeInDown 0.8s ease-out;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .header-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 700;
      background: linear-gradient(135deg, #ff8c00, #ffa500);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.5px;
    }

    nav a {
      text-decoration: none;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.95rem;
      margin-left: 2rem;
      transition: all 0.3s ease;
      position: relative;
    }

    nav a:hover {
      color: #ffffff;
    }

    nav a.active {
      color: #ffffff;
    }

    nav a.active:after {
      width: 100% !important;
    }

    nav a:after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 0;
      height: 2px;
      background: linear-gradient(135deg, #ff8c00, #ffa500);
      transition: width 0.3s ease;
    }

    nav a:hover:after {
      width: 100%;
    }

    main {
      padding: 6rem 0;
      min-height: calc(100vh - 140px);
      display: flex;
      align-items: center;
    }

    .decrypt-container {
      max-width: 600px;
      margin: 0 auto;
      width: 100%;
      animation: slideUp 1s ease-out;
    }

    h1 {
      font-size: 3rem;
      line-height: 1.2;
      margin-bottom: 1rem;
      font-weight: 800;
      letter-spacing: -1.5px;
      background: linear-gradient(135deg, #ffffff, #ff8c00);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .intro {
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 2.5rem;
      line-height: 1.8;
    }

    .decrypt-section {
      background: rgba(255, 140, 0, 0.08);
      border: 1px solid rgba(255, 140, 0, 0.25);
      border-radius: 16px;
      padding: 2.5rem;
      backdrop-filter: blur(10px);
    }

    form {
      display: grid;
      gap: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    label {
      font-size: 0.95rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: rgba(255, 255, 255, 0.9);
      text-transform: capitalize;
    }

    input[type="password"] {
      font-size: 1rem;
      padding: 1rem;
      border: 1px solid rgba(255, 140, 0, 0.3);
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.05);
      color: #ffffff;
      font-family: inherit;
      transition: all 0.3s ease;
    }

    input[type="password"]::placeholder {
      color: rgba(255, 255, 255, 0.5);
    }

    input[type="password"]:focus {
      outline: none;
      border-color: #ff8c00;
      background: rgba(255, 140, 0, 0.1);
      box-shadow: 0 0 20px rgba(255, 140, 0, 0.3);
    }

    button {
      background: linear-gradient(135deg, #ff8c00, #ffa500);
      color: #ffffff;
      border: none;
      padding: 1rem 2rem;
      font-size: 1rem;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 8px 25px rgba(255, 140, 0, 0.4);
      min-height: 44px;
      -webkit-appearance: none;
      -moz-appearance: none;
      appearance: none;
    }

    button:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 12px 35px rgba(255, 140, 0, 0.6);
    }

    button:active:not(:disabled) {
      transform: translateY(0);
    }

    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .message-container {
      margin-top: 1rem;
      min-height: 1.5rem;
    }

    .status {
      color: #ffa500;
      font-weight: 600;
      font-size: 0.95rem;
      animation: fadeInUp 0.3s ease;
    }

    .error {
      background: rgba(239, 68, 68, 0.1);
      color: #fca5a5;
      padding: 1rem;
      border-radius: 10px;
      border: 1px solid rgba(239, 68, 68, 0.3);
      font-size: 0.95rem;
      animation: fadeInUp 0.5s ease-out;
    }

    .info-box {
      background: rgba(255, 140, 0, 0.08);
      border: 1px solid rgba(255, 140, 0, 0.25);
      border-radius: 10px;
      padding: 1.5rem;
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 1.5rem;
    }

    .info-box strong {
      display: block;
      margin-bottom: 0.5rem;
      color: #ffa500;
      font-size: 1rem;
    }

    footer {
      border-top: 1px solid rgba(255, 140, 0, 0.15);
      padding: 4rem 0;
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.95rem;
      background: rgba(10, 10, 10, 0.5);
      animation: fadeInUp 1.2s ease-out;
    }

    .footer-content {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
      margin-bottom: 2rem;
    }

    .footer-section h3 {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 700;
      margin-bottom: 1.5rem;
      color: #ffffff;
    }

    .footer-section a {
      display: block;
      color: rgba(255, 255, 255, 0.6);
      text-decoration: none;
      margin-bottom: 0.75rem;
      transition: all 0.3s ease;
    }

    .footer-section a:hover {
      color: #ffa500;
      transform: translateX(5px);
    }

    .footer-bottom {
      border-top: 1px solid rgba(255, 140, 0, 0.1);
      padding-top: 2rem;
      color: rgba(255, 255, 255, 0.5);
    }

    @media (max-width: 768px) {
      body {
        background: linear-gradient(135deg, #0a0a0a 0%, #1a1410 100%);
      }

      h1 {
        font-size: 2rem;
      }

      header {
        padding: 1.5rem 0;
      }

      .container {
        padding: 0 1.5rem;
      }

      .decrypt-container {
        padding: 0 1rem;
      }

      .decrypt-section {
        padding: 1.5rem;
      }

      input[type="password"] {
        font-size: 16px;
        padding: 0.75rem;
      }

      button {
        width: 100%;
        padding: 0.875rem 1.5rem;
      }

      main {
        padding: 2rem 0;
      }

      footer {
        padding: 2rem 0;
      }

      .header-content {
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
      }

      nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        width: 100%;
      }

      nav a {
        margin-left: 0;
        font-size: 0.9rem;
      }

      .footer-content {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <div class="logo">BurnLink</div>
        <nav>
          <a href="/">Home</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <div class="container">
      <div class="decrypt-container">
        <h1>Decrypt & Download</h1>
        <p class="intro">Your secure file is ready. This link will be burned after download to ensure one-time access only.</p>

        <% if (error) { %>
          <div class="error"><%= error %></div>
        <% } %>

        <div class="decrypt-section">
          <div class="info-box">
            <strong>🔒 End-to-End Encrypted</strong>
            All decryption happens in your browser. We never see your files.
          </div>

          <form id="decrypt-form">
            <% if (requiresPassword) { %>
              <div class="form-group">
                <label for="password">Password Required</label>
                <input type="password" id="password" name="password" placeholder="Enter the password provided by sender" required />
              </div>
            <% } else { %>
              <div class="form-group">
                <label for="password">Password (if sender set one)</label>
                <input type="password" id="password" name="password" placeholder="Leave blank if no password" />
              </div>
            <% } %>

            <button id="download-btn" type="submit">Decrypt & Download</button>
            
            <div class="message-container">
              <span id="decrypt-status" class="status" aria-live="polite"></span>
              <span id="decrypt-error" class="error" aria-live="polite"></span>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>Product</h3>
          <a href="/">Share Files</a>
          <a href="/about">How It Works</a>
        </div>
        <div class="footer-section">
          <h3>Resources</h3>
          <a href="https://github.com/Joy-Majumder/BurnLink" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://github.com/Joy-Majumder/BurnLink#readme" target="_blank" rel="noopener noreferrer">Documentation</a>
        </div>
        <div class="footer-section">
          <h3>Developer</h3>
          <a href="https://github.com/Joy-Majumder" target="_blank" rel="noopener noreferrer">Joy Majumdar</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 BurnLink. Share files. Encrypted. Ephemeral.</p>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      var PBKDF2_ITERATIONS = 210000;
      var textEncoder = new TextEncoder();
      var fileId = "<%= fileId %>";
      var requiresPassword = <%= requiresPassword ? "true" : "false" %>;
      var encryptedPayload = null;
      var originalFileName = "download.bin";

      var form = document.getElementById("decrypt-form");
      var passwordInput = document.getElementById("password");
      var downloadBtn = document.getElementById("download-btn");
      var statusEl = document.getElementById("decrypt-status");
      var errorEl = document.getElementById("decrypt-error");

      function setStatus(message) {
        statusEl.textContent = message || "";
        errorEl.textContent = "";
      }

      function setError(message) {
        errorEl.textContent = message || "";
        statusEl.textContent = "";
      }

      function fromBase64Url(base64Url) {
        var base64 = base64Url.replace(/-/g, "+").replace(/_/g, "/");
        while (base64.length % 4) {
          base64 += "=";
        }
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i += 1) {
          bytes[i] = binary.charCodeAt(i);
        }
        return bytes;
      }

      function parseEnvelope(payload) {
        if (payload.length < 8) {
          throw new Error("Encrypted file is invalid.");
        }

        // magic "FSE1"
        if (
          payload[0] !== 70 ||
          payload[1] !== 83 ||
          payload[2] !== 69 ||
          payload[3] !== 49
        ) {
          throw new Error("Unsupported encrypted file format.");
        }

        var version = payload[4];
        var mode = payload[5];
        var saltLen = payload[6];
        var ivLen = payload[7];

        if (version !== 1) {
          throw new Error("Unsupported encryption version.");
        }

        var offset = 8;
        var salt = payload.slice(offset, offset + saltLen);
        offset += saltLen;

        var iv = payload.slice(offset, offset + ivLen);
        offset += ivLen;

        var ciphertext = payload.slice(offset);
        if (ciphertext.length === 0) {
          throw new Error("Encrypted file payload is empty.");
        }

        return {
          mode: mode,
          salt: salt,
          iv: iv,
          ciphertext: ciphertext,
        };
      }

      async function deriveKeyFromPassword(password, salt) {
        var baseKey = await crypto.subtle.importKey(
          "raw",
          textEncoder.encode(password),
          "PBKDF2",
          false,
          ["deriveKey"]
        );

        return crypto.subtle.deriveKey(
          {
            name: "PBKDF2",
            salt: salt,
            iterations: PBKDF2_ITERATIONS,
            hash: "SHA-256",
          },
          baseKey,
          {
            name: "AES-GCM",
            length: 256,
          },
          false,
          ["decrypt"]
        );
      }

      async function importRawAesKey(rawKey) {
        return crypto.subtle.importKey(
          "raw",
          rawKey,
          { name: "AES-GCM" },
          false,
          ["decrypt"]
        );
      }

      function getLinkKeyBytes() {
        var hash = window.location.hash || "";
        if (!hash.startsWith("#")) return null;
        var params = new URLSearchParams(hash.slice(1));
        var keyString = params.get("k");
        if (!keyString) return null;

        try {
          return fromBase64Url(keyString);
        } catch (error) {
          return null;
        }
      }

      async function fetchEncryptedPayload() {
        if (encryptedPayload) {
          return encryptedPayload;
        }

        setStatus("Fetching encrypted file...");
        var response;
        if (requiresPassword) {
          response = await fetch("/file/" + fileId + "/raw", {
            method: "POST",
            headers: {
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: new URLSearchParams({
              password: passwordInput.value || "",
            }).toString(),
          });
        } else {
          response = await fetch("/file/" + fileId + "/raw");
        }

        if (!response.ok) {
          var message = "This link is invalid or already used.";
          try {
            var body = await response.json();
            if (body && body.error) {
              message = body.error;
            }
          } catch (e) {
            // ignore JSON parse errors
          }
          throw new Error(message);
        }

        var fileNameHeader = response.headers.get("x-file-name");
        if (fileNameHeader) {
          originalFileName = decodeURIComponent(fileNameHeader);
        }

        encryptedPayload = new Uint8Array(await response.arrayBuffer());
        return encryptedPayload;
      }

      async function decryptPayload(payload, password) {
        var envelope = parseEnvelope(payload);
        var key;

        if (envelope.mode === 1) {
          if (!password) {
            throw new Error("Password required for this file.");
          }
          key = await deriveKeyFromPassword(password, envelope.salt);
        } else if (envelope.mode === 2) {
          var linkKeyBytes = getLinkKeyBytes();
          if (!linkKeyBytes || linkKeyBytes.length !== 32) {
            throw new Error("Missing or invalid decryption key in link.");
          }
          key = await importRawAesKey(linkKeyBytes);
        } else {
          throw new Error("Unknown encryption mode.");
        }

        var plainBuffer = await crypto.subtle.decrypt(
          { name: "AES-GCM", iv: envelope.iv },
          key,
          envelope.ciphertext
        );

        return new Uint8Array(plainBuffer);
      }

      function triggerDownload(bytes, fileName) {
        var blob = new Blob([bytes], { type: "application/octet-stream" });
        var objectUrl = URL.createObjectURL(blob);
        var a = document.createElement("a");
        a.href = objectUrl;
        a.download = fileName || "download.bin";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(objectUrl);
      }

      async function handleDecrypt(event) {
        event.preventDefault();
        setError("");
        setStatus("");
        downloadBtn.disabled = true;

        try {
          var payload = await fetchEncryptedPayload();
          setStatus("Decrypting in your browser...");
          var plainBytes = await decryptPayload(payload, passwordInput.value || "");
          triggerDownload(plainBytes, originalFileName);
          setStatus("Download complete.");
        } catch (error) {
          setError(error.message || "Failed to decrypt file.");
        } finally {
          downloadBtn.disabled = false;
        }
      }

      form.addEventListener("submit", handleDecrypt);
    })();
  </script>
</body>
</html>
